---
// Language splash at "/". Suggests a locale from navigator.language and
// forwards once; without JS it shows links and meta-refreshes to /de/ (default).
// Link scrapers don't run that JS, so the social card baked in here is static —
// German, matching the default locale / x-default and the /de/ canonical.
import { site } from '../data/site';
import { app, homeMeta } from '../data/apps';
const title = `${site.name} — ${homeMeta.title.de}`;
const ogImage = new URL(app.icon, site.url).href;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={homeMeta.description.de} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="canonical" href={site.url + '/de/'} />
    <link rel="alternate" hreflang="de" href={site.url + '/de/'} />
    <link rel="alternate" hreflang="en" href={site.url + '/en/'} />
    <link rel="alternate" hreflang="x-default" href={site.url + '/de/'} />
    <meta name="theme-color" content="#0277BD" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={homeMeta.social.de} />
    <meta property="og:url" content={site.url + '/de/'} />
    <meta property="og:locale" content="de_DE" />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={homeMeta.social.de} />
    <meta name="twitter:image" content={ogImage} />

    <noscript><meta http-equiv="refresh" content="0; url=/de/" /></noscript>
    <script is:inline>
      (function () {
        try {
          const pref = (navigator.languages && navigator.languages[0]) || navigator.language || 'de';
          const lang = pref.toLowerCase().indexOf('de') === 0 ? 'de' : 'en';
          location.replace('/' + lang + '/');
        } catch {
          location.replace('/de/');
        }
      })();
    </script>
    <style>
      html { color-scheme: light dark; }
      body {
        margin: 0; min-height: 100svh; display: grid; place-items: center;
        font-family: system-ui, sans-serif; color: light-dark(#0B2530, #E7F1F6);
        background: light-dark(#F4FAFE, #060F16); padding: 2rem; text-align: center;
      }
      .card { display: grid; gap: 1.25rem; justify-items: center; }
      h1 { font-size: 1.5rem; margin: 0; font-weight: 700; }
      p { margin: 0; color: light-dark(#42626f, #9db4bf); }
      .langs { display: flex; gap: 0.8rem; }
      a {
        padding: 0.7rem 1.4rem; border-radius: 999px; text-decoration: none; font-weight: 650;
        color: #fff; background: linear-gradient(135deg, #0277BD, #00838F);
      }
      a + a { background: linear-gradient(135deg, #00838F, #0277BD); }
      /* This page doesn't load theme.css, so define its own focus ring (WCAG 2.4.7). */
      a:focus-visible { outline: 2.5px solid #fff; outline-offset: 3px; }
    </style>
  </head>
  <body>
    <div class="card">
      <h1>PoolPilot</h1>
      <p>Sprache wählen / Choose your language</p>
      <div class="langs">
        <a href="/de/" hreflang="de" lang="de">Deutsch</a>
        <a href="/en/" hreflang="en" lang="en">English</a>
      </div>
    </div>
  </body>
</html>
