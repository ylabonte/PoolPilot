---
import Logo from './Logo.astro';
import LangToggle from './LangToggle.astro';
import { path, useTranslations, type Lang, type RouteKey } from '../i18n/ui';

interface Props {
  lang: Lang;
  pageKey: RouteKey;
}
const { lang, pageKey } = Astro.props;
const t = useTranslations(lang);

const nav: { href: string; label: string; key?: RouteKey }[] = [
  { href: `${path('home', lang)}#features`, label: t('nav.features') },
  { href: path('support', lang), label: t('nav.support'), key: 'support' },
  { href: path('news', lang), label: t('nav.news'), key: 'news' },
];
---

<header class="site-header">
  <div class="container site-header__inner">
    <Logo href={path('home', lang)} />

    <details class="nav" name="nav-menu">
      <summary class="nav__toggle" aria-label={t('nav.menu')}>
        <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round">
          <path class="nav__icon-open" d="M4 7h16M4 12h16M4 17h16" />
          <path class="nav__icon-close" d="M6 6l12 12M18 6L6 18" />
        </svg>
      </summary>
      <nav class="nav__links" aria-label={t('nav.menu')}>
        {nav.map((item) => (
          <a
            href={item.href}
            aria-current={item.key && item.key === pageKey ? 'page' : undefined}
          >
            {item.label}
          </a>
        ))}
        <span class="nav__lang"><LangToggle lang={lang} pageKey={pageKey} /></span>
      </nav>
    </details>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
  }
  /* The translucent blur lives on a pseudo-element, not on .site-header itself:
     backdrop-filter turns its element into a "backdrop root", and a backdrop
     root clips any descendant's backdrop-filter to its own subtree. With the
     blur on .site-header directly, the mobile nav dropdown (a descendant) could
     only blur header-internal content — i.e. nothing — so its glass never
     rendered. Keeping .site-header filter-free lets the dropdown blur the page. */
  .site-header::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: -1; /* behind the header content, still above page content */
    background: color-mix(in oklch, var(--bg) 72%, transparent);
    backdrop-filter: blur(14px) saturate(1.3);
    -webkit-backdrop-filter: blur(14px) saturate(1.3);
    border-bottom: 1px solid var(--line-soft);
  }
  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    min-height: 4.1rem;
  }

  .nav { position: relative; }

  /* Toggle is hidden on desktop; links sit inline. */
  .nav__toggle {
    display: none;
    list-style: none;
    cursor: pointer;
    color: var(--ink);
    padding: 0.4rem;
    border-radius: var(--r-1);
  }
  .nav__toggle::-webkit-details-marker { display: none; }
  .nav__icon-close { display: none; }

  .nav__links {
    display: flex;
    align-items: center;
    gap: clamp(0.6rem, 2vw, 1.8rem);
  }
  /* A closed <details> collapses its content to zero size (UA hides
     ::details-content). Desktop has no toggle, so reveal it regardless of the
     open state. The mobile query below re-collapses it behind the toggle. */
  .nav::details-content { content-visibility: visible; }
  .nav__lang { display: inline-flex; }
  .nav__links a {
    color: var(--ink-soft);
    text-decoration: none;
    font-weight: 600;
    padding: 0.4rem 0.2rem;
    transition: color 0.18s;
  }
  .nav__links a:hover { color: var(--ink); }
  .nav__links a[aria-current='page'] {
    color: var(--c-primary-ink);
    text-decoration: underline;
    text-underline-offset: 0.4em;
    text-decoration-thickness: 0.12em;
  }

  /* Mobile: collapse links into a glass dropdown behind the toggle. */
  @media (max-width: 46rem) {
    .nav__toggle { display: inline-flex; }
    .nav[open] .nav__icon-open { display: none; }
    .nav[open] .nav__icon-close { display: inline; }
    /* Re-collapse the content (the desktop rule above forced it visible). */
    .nav:not([open])::details-content { content-visibility: hidden; }
    .nav__links { display: none; }
    .nav[open] .nav__links {
      display: flex;
      position: absolute;
      right: 0;
      top: calc(100% + 0.6rem);
      flex-direction: column;
      align-items: flex-start;
      gap: 0.4rem;
      min-width: 12rem;
      padding: 0.8rem;
      background: var(--glass-bg);
      border: 1px solid var(--glass-border);
      border-radius: var(--r-2);
      box-shadow: var(--glass-shadow);
      backdrop-filter: blur(16px) saturate(1.4);
      -webkit-backdrop-filter: blur(16px) saturate(1.4);
    }
    .nav__links a { padding: 0.5rem 0.4rem; width: 100%; }
    .nav__lang { margin-top: 0.4rem; }
  }
</style>
