---
import type { Controller } from '../data/apps';
import type { Lang } from '../i18n/ui';

interface Props {
  controller: Controller;
  lang: Lang;
}
const { controller, lang } = Astro.props;
const accentStyle = `--accent: light-dark(${controller.accent.light}, ${controller.accent.dark});`;
---

<article class="ctrlcard glass" style={accentStyle}>
  <header class="ctrlcard__head">
    <span class="ctrlcard__dot" aria-hidden="true"></span>
    <h3 class="ctrlcard__name">{controller.name}</h3>
  </header>
  <p class="ctrlcard__blurb">{controller.blurb[lang]}</p>
  <ul class="ctrlcard__list" role="list">
    {controller.highlights[lang].map((h) => (
      <li>
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5" /></svg>
        <span>{h}</span>
      </li>
    ))}
  </ul>
</article>

<style>
  .ctrlcard {
    padding: clamp(1.4rem, 3vw, 2.1rem);
    display: flex; flex-direction: column; gap: 1rem;
    position: relative; overflow: hidden;
  }
  .ctrlcard::before {
    content: ''; position: absolute; inset: 0 0 auto 0; height: 4px;
    background: linear-gradient(90deg, var(--accent), color-mix(in oklch, var(--accent) 35%, transparent));
  }
  .ctrlcard__head { display: flex; align-items: center; gap: 0.6rem; }
  .ctrlcard__dot {
    width: 0.7rem; height: 0.7rem; border-radius: 50%; flex: none;
    background: var(--accent);
    animation: ctrldot 2.4s var(--ease) infinite;
  }
  /* Gentle "live" pulse — an accent ring expands and fades outward. */
  @keyframes ctrldot {
    0%   { box-shadow: 0 0 0 0 color-mix(in oklch, var(--accent) 45%, transparent); }
    70%  { box-shadow: 0 0 0 0.5rem color-mix(in oklch, var(--accent) 0%, transparent); }
    100% { box-shadow: 0 0 0 0 color-mix(in oklch, var(--accent) 0%, transparent); }
  }
  .ctrlcard__name { font-size: var(--step-2); }
  .ctrlcard__blurb { color: var(--ink-soft); }
  .ctrlcard__list { list-style: none; padding: 0; margin: 0; display: grid; gap: 0.6rem; }
  .ctrlcard__list li { display: flex; gap: 0.6rem; align-items: flex-start; font-weight: 600; }
  .ctrlcard__list svg { color: var(--accent); flex: none; margin-top: 0.15em; }
</style>
