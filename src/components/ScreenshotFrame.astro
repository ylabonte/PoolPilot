---
import { type Lang } from '../i18n/ui';

interface Props {
  variant?: 'phone' | 'watch';
  label: string; // describes the intended screenshot (also the a11y label)
  lang: Lang;
  src?: string; // when a real screenshot exists, drop it in here
}
const { variant = 'phone', label, lang, src } = Astro.props;
const placeholder = lang === 'de' ? 'Screenshot folgt' : 'Screenshot coming';
---

<figure class={`shot shot--${variant}`} aria-label={label}>
  <div class="shot__device">
    {variant === 'phone' && <span class="shot__notch" aria-hidden="true"></span>}
    <div class="shot__screen">
      {src ? (
        <img src={src} alt={label} loading="lazy" decoding="async" />
      ) : (
        <div class="shot__placeholder">
          <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
            <rect x="3" y="5" width="18" height="14" rx="2" />
            <circle cx="8.5" cy="10" r="1.6" />
            <path d="M5 17l4.5-4.5L13 16l3-3 3 3" />
          </svg>
          <span>{placeholder}</span>
          <small>{label}</small>
        </div>
      )}
    </div>
  </div>
</figure>

<style>
  .shot { margin: 0; }
  .shot__device {
    position: relative;
    border-radius: 2rem;
    padding: 0.6rem;
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    box-shadow: var(--glass-shadow);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }
  .shot--phone .shot__device { width: min(15rem, 70vw); aspect-ratio: 9 / 19; }
  .shot--watch .shot__device { width: 8.5rem; aspect-ratio: 5 / 6; border-radius: 2.4rem; }

  .shot__notch {
    position: absolute; top: 0.95rem; left: 50%; transform: translateX(-50%);
    width: 32%; height: 0.5rem; border-radius: 999px;
    background: color-mix(in oklch, var(--ink) 55%, transparent); z-index: 2;
  }
  .shot__screen {
    height: 100%; border-radius: 1.5rem; overflow: hidden;
    background:
      radial-gradient(120% 80% at 50% 0%, color-mix(in oklch, var(--accent) 24%, transparent), transparent 60%),
      var(--bg);
    display: grid; place-items: center;
  }
  .shot--watch .shot__screen { border-radius: 1.9rem; }
  .shot__screen img { width: 100%; height: 100%; object-fit: cover; }

  .shot__placeholder {
    display: grid; justify-items: center; gap: 0.4rem; padding: 1rem; text-align: center;
    color: var(--ink-faint);
  }
  .shot__placeholder span { font-weight: 700; font-size: 0.85rem; color: var(--ink-soft); }
  .shot__placeholder small { font-size: 0.68rem; line-height: 1.3; max-width: 12rem; }
</style>
